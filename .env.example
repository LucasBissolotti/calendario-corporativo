# ===========================================
# CONFIGURAÇÃO DO AMBIENTE - CALENDÁRIO CORPORATIVO
# ===========================================
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env com credenciais reais!

# --- Banco de Dados ---
DB_PATH=database/calendario.db
DB_BACKUP_DIR=database/backups
DB_BACKUP_MAX=20

# --- Configurações de E-mail (SMTP) ---
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USER=noreply@seudominio.com.br
SMTP_PASSWORD=sua_senha_smtp_aqui
SMTP_FROM_EMAIL=noreply@seudominio.com.br
SMTP_FROM_NAME="Calendário Corporativo"

# --- Configurações Gerais ---
SITE_TITLE="Calendário Corporativo"
ALLOW_FILE_DOWNLOADS=false

# --- Domínio permitido para registro (regex sem delimitadores) ---
ALLOWED_EMAIL_DOMAIN='@seudominio\.com\.br$'
